# ContactSnap AI
# NOTE: never put AI provider API keys in VITE_ variables — anything prefixed
# with VITE_ is embedded in the shipped client bundle and readable by anyone.
# AI extraction must call a server-side (or Tauri backend) proxy that holds the key.
VITE_AI_EXTRACTION_DEFAULT=off

# Google OAuth / People API
VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_REDIRECT_URI=http://localhost:5173/oauth/google/callback

# Microsoft Entra / Graph API
VITE_MICROSOFT_CLIENT_ID=
VITE_MICROSOFT_TENANT_ID=common
VITE_MICROSOFT_REDIRECT_URI=http://localhost:5173/oauth/microsoft/callback

# Optional CRM exports
VITE_HUBSPOT_CLIENT_ID=
VITE_SALESFORCE_CLIENT_ID=
