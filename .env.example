# ContactSnap AI
VITE_OPENAI_API_KEY=
VITE_OPENAI_BASE_URL=https://api.openai.com/v1
VITE_AI_EXTRACTION_DEFAULT=off

# Google OAuth / People API
VITE_GOOGLE_CLIENT_ID=
