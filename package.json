{
  "name": "contactsnap-ai",
  "version": "0.1.0",
  "private": true,
  "description": "ContactSnap AI captures messy contact text and saves structured contacts to Google, Outlook, and CRM systems.",
  "type": "module",
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev": "npm run dev -w @contactsnap/web",
    "test": "npm run test -w @contactsnap/parser",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  },
  "engines": {
    "node": ">=22"
  }
}
